# Part 3 — Node class for the Linked-List version
class Node:
    def __init__(self, value):
        self.value = value
        self.next = None

# Part 1 — Build a stack class (List-based)
class Stack:
    def __init__(self):
        self.items = []

    def push(self, value):
        self.items.append(value)

    def pop(self):
        if not self.is_empty():
            return self.items.pop()
        return None

    def peek(self):
        if not self.is_empty():
            return self.items[-1]
        return None

    def is_empty(self):
        return len(self.items) == 0

    def size(self):
        return len(self.items)

# Part 3 — Linked-list version
class LinkedStack:
    def __init__(self):
        self.head = None
        self._size = 0

    def push(self, value):
        new_node = Node(value)
        new_node.next = self.head
        self.head = new_node
        self._size += 1

    def pop(self):
        if self.is_empty():
            return None
        popped_value = self.head.value
        self.head = self.head.next
        self._size -= 1
        return popped_value

    def peek(self):
        return self.head.value if self.head else None

    def is_empty(self):
        return self.head is None

    def size(self):
        return self._size

# Part 2 — Use the stack to solve problems
def reverse_string(text):
    s = Stack()
    for char in text:
        s.push(char)
    
    reversed_text = ""
    while not s.is_empty():
        reversed_text += s.pop()
    return reversed_text

def is_balanced(expression):
    s = Stack()
    pairs = {')': '(', ']': '[', '}': '{'}
    for char in expression:
        if char in "([{":
            s.push(char)
        elif char in ")]}":
            if s.is_empty() or s.pop() != pairs[char]:
                return False
    return s.is_empty()

class UndoSystem:
    def __init__(self):
        self.history = Stack()

    def perform_action(self, action):
        print(f"Action: {action}")
        self.history.push(action)

    def undo(self):
        action = self.history.pop()
        if action:
            print(f"Undoing: {action}")
        else:
            print("Nothing to undo.")

